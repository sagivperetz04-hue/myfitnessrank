#!/usr/bin/env bash
# Brings up the full local environment (kind + ingress + ArgoCD + app).
# Idempotent — safe to re-run anytime, e.g. after a host reboot.
# REBUILD=1 ./start  rebuilds the app images and restarts the workloads.
set -euo pipefail

cd "$(dirname "$0")"
export PATH="$HOME/.local/bin:$PATH"

CLUSTER=myfitnessrank
NODE="${CLUSTER}-control-plane"
APP_NS=myfitnessrank
INGRESS_MANIFEST=https://raw.githubusercontent.com/kubernetes/ingress-nginx/controller-v1.15.1/deploy/static/provider/kind/deploy.yaml
ARGOCD_MANIFEST=https://raw.githubusercontent.com/argoproj/argo-cd/v3.4.3/manifests/install.yaml
# Kept outside the repo so it can never be committed; create-once like the other secrets.
ARGOCD_PW_FILE="${HOME}/.config/myfitnessrank/argocd-admin-password"

log() { printf '\n==> %s\n' "$*"; }
die() { echo "ERROR: $*" >&2; exit 1; }

for tool in docker kind kubectl openssl; do
  command -v "$tool" >/dev/null || die "$tool not found on PATH"
done
docker info >/dev/null 2>&1 || die "docker daemon is not running"

if kind get clusters 2>/dev/null | grep -qx "$CLUSTER"; then
  # After a host reboot the kind node container still exists but is stopped
  if [ "$(docker inspect -f '{{.State.Running}}' "$NODE")" != "true" ]; then
    log "Starting stopped cluster node"
    docker start "$NODE" >/dev/null
  fi
else
  log "Creating kind cluster"
  kind create cluster --config deploy/kind/kind-config.yaml
fi

kubectl config use-context "kind-${CLUSTER}" >/dev/null

log "Waiting for Kubernetes API"
for _ in $(seq 1 60); do
  kubectl get --raw /readyz >/dev/null 2>&1 && break
  sleep 2
done
kubectl get --raw /readyz >/dev/null 2>&1 || die "Kubernetes API did not become ready"

if ! kubectl get namespace ingress-nginx >/dev/null 2>&1; then
  log "Installing ingress-nginx"
  kubectl apply -f "$INGRESS_MANIFEST"
fi

ARGOCD_FRESH=0
if ! kubectl get namespace argocd >/dev/null 2>&1; then
  log "Installing ArgoCD"
  kubectl create namespace argocd
  # server-side: the ApplicationSet CRD exceeds the client-side annotation size limit
  kubectl apply --server-side -n argocd -f "$ARGOCD_MANIFEST"
  ARGOCD_FRESH=1
fi

image_in_node() {
  docker exec "$NODE" crictl images -o json 2>/dev/null | grep -q "docker.io/library/$1\""
}

# The Helm values are the single source of truth for the image tag, so a chart
# bump (e.g. backend 0.1.0 -> 0.1.1) can't drift from what ./start builds.
chart_image_tag() {
  awk '/^image:/{f=1} f && /tag:/{gsub(/[" ]/,"",$2); print $2; exit}' "helm/$1/values.yaml"
}

build_and_load() {
  local repo=$1 dir=$2 version
  version=$(chart_image_tag "$dir")
  [ -n "$version" ] || die "could not read image tag from helm/$dir/values.yaml"
  local tag="$repo:$version"
  if [ "${REBUILD:-0}" = 1 ] || ! image_in_node "$tag"; then
    log "Building and loading $tag"
    docker build -t "$tag" "$dir"
    kind load docker-image "$tag" --name "$CLUSTER"
  fi
}

build_and_load myfitnessrank-backend backend
build_and_load myfitnessrank-frontend frontend
build_and_load myfitnessrank-auth auth
build_and_load myfitnessrank-leaderboards leaderboards

kubectl get namespace "$APP_NS" >/dev/null 2>&1 || kubectl create namespace "$APP_NS"

# Create-once: postgres' PVC keeps the password it was initialized with,
# so regenerating this secret would lock the backend out of the existing DB
if ! kubectl -n "$APP_NS" get secret fitrank-db-credentials >/dev/null 2>&1; then
  log "Creating DB credentials secret"
  kubectl -n "$APP_NS" create secret generic fitrank-db-credentials \
    --from-literal=username=fitrank \
    --from-literal=password="$(openssl rand -hex 16)" \
    --from-literal=database=fitrank
fi

# Create-once: the auth postgres' PVC keeps the password it was initialized with,
# so regenerating this secret would lock the auth service out of its existing DB
if ! kubectl -n "$APP_NS" get secret auth-db-credentials >/dev/null 2>&1; then
  log "Creating auth DB credentials secret"
  kubectl -n "$APP_NS" create secret generic auth-db-credentials \
    --from-literal=username=fitauth \
    --from-literal=password="$(openssl rand -hex 16)" \
    --from-literal=database=fitauth
fi

# Create-once: rotating the JWT signing key would invalidate every issued token
if ! kubectl -n "$APP_NS" get secret jwt-signing-key >/dev/null 2>&1; then
  log "Creating JWT signing key secret"
  kubectl -n "$APP_NS" create secret generic jwt-signing-key \
    --from-literal=signing-key="$(openssl rand -hex 32)"
fi

# Create-once: the leaderboards postgres' PVC keeps the password it was initialized
# with, so regenerating this secret would lock the service out of its existing DB
if ! kubectl -n "$APP_NS" get secret leaderboards-db-credentials >/dev/null 2>&1; then
  log "Creating leaderboards DB credentials secret"
  kubectl -n "$APP_NS" create secret generic leaderboards-db-credentials \
    --from-literal=username=leaderboards \
    --from-literal=password="$(openssl rand -hex 16)" \
    --from-literal=database=leaderboards
fi

# Create-once: rotating this Fernet key would make every encrypted lifter name
# undecryptable. urlsafe base64 of 32 bytes is a valid Fernet key — openssl only,
# keeping the script free of a python/cryptography dependency.
if ! kubectl -n "$APP_NS" get secret leaderboards-enc-key >/dev/null 2>&1; then
  log "Creating leaderboards encryption key secret"
  kubectl -n "$APP_NS" create secret generic leaderboards-enc-key \
    --from-literal=fernet-key="$(openssl rand -base64 32 | tr '+/' '-_')"
fi

# ArgoCD's bundled initial-admin password is regenerated on every fresh install.
# Own it instead: persist a password locally (create-once, outside git) and stamp
# it into argocd-secret only when ArgoCD was just installed — so normal reboots
# keep the existing secret and don't invalidate the current UI session.
if [ ! -f "$ARGOCD_PW_FILE" ]; then
  log "Generating ArgoCD admin password"
  mkdir -p "$(dirname "$ARGOCD_PW_FILE")"
  ( umask 077; openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 24 > "$ARGOCD_PW_FILE" )
fi

if [ "$ARGOCD_FRESH" = 1 ]; then
  log "Setting ArgoCD admin password"
  kubectl -n argocd rollout status deploy/argocd-server --timeout=300s
  argocd_pw="$(cat "$ARGOCD_PW_FILE")"
  # The argocd image bundles the CLI, so bcrypt the password in-cluster — no extra
  # host tooling and no server login needed.
  argocd_hash="$(kubectl -n argocd exec deploy/argocd-server -- \
    argocd account bcrypt --password "$argocd_pw")"
  kubectl -n argocd patch secret argocd-secret --type merge -p \
    "{\"stringData\":{\"admin.password\":\"$argocd_hash\",\"admin.passwordMtime\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}}"
  kubectl -n argocd rollout restart deploy/argocd-server
  kubectl -n argocd rollout status deploy/argocd-server --timeout=300s
fi

log "Applying ArgoCD root app"
kubectl apply -f deploy/argocd/root-app.yaml

log "Waiting for ingress controller"
kubectl -n ingress-nginx wait deployment/ingress-nginx-controller \
  --for=condition=Available --timeout=300s

if [ "${REBUILD:-0}" = 1 ]; then
  log "Restarting workloads to pick up rebuilt images"
  kubectl -n "$APP_NS" rollout restart deployment,statefulset 2>/dev/null || true
fi

wait_created() {
  for _ in $(seq 1 60); do
    kubectl -n "$APP_NS" get "$1" >/dev/null 2>&1 && return 0
    sleep 5
  done
  die "$1 never appeared — check ArgoCD sync status"
}

log "Waiting for ArgoCD to sync the app (first sync can take a few minutes)"
for workload in statefulset/postgres statefulset/postgres-auth statefulset/postgres-leaderboards deployment/auth deployment/backend deployment/frontend deployment/leaderboards; do
  wait_created "$workload"
  kubectl -n "$APP_NS" rollout status "$workload" --timeout=300s
done

# initdb seeds global_standards only on a fresh PVC, so a persisted volume keeps
# whatever it was first loaded with. Re-seed every run to reconcile the table to
# the committed standards — TRUNCATE + INSERT in one transaction is idempotent.
log "Reconciling global standards"
{
  echo "BEGIN;"
  echo "TRUNCATE global_standards;"
  cat backend/scripts/seed_global_standards.sql
  echo "COMMIT;"
} | kubectl -n "$APP_NS" exec -i postgres-0 -- \
      sh -c 'psql -q -v ON_ERROR_STOP=1 -U "$POSTGRES_USER" -d "$POSTGRES_DB"' >/dev/null \
  || die "global standards re-seed failed"

# A port-forward is process-bound and dies on host/cluster restart, so the
# ArgoCD UI is unreachable after a reboot until it's relaunched. Reconcile it
# here: drop any stale forwarder and start a fresh detached one.
ARGOCD_PF_PORT=8081
log "Starting ArgoCD UI port-forward (localhost:${ARGOCD_PF_PORT})"
pkill -f "port-forward svc/argocd-server ${ARGOCD_PF_PORT}:443" 2>/dev/null || true
nohup kubectl -n argocd port-forward svc/argocd-server "${ARGOCD_PF_PORT}:443" \
  >/tmp/argocd-port-forward.log 2>&1 &
disown

log "Ready"
echo "App:       http://localhost:8080"
echo "ArgoCD UI: https://localhost:${ARGOCD_PF_PORT}  (port-forward running in background; log: /tmp/argocd-port-forward.log)"
echo "           user: admin   password: cat ${ARGOCD_PW_FILE}"
